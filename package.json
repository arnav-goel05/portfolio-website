{
  "name": "portfolio-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "audit:seo": "node scripts/audit-seo.mjs",
    "audit:structure": "node scripts/audit-structure.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run src",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "check": "npm run check:quality",
    "check:quality": "npm run format:check && npm run audit:structure && npm run lint && npm run test:unit && npm run build",
    "check:ci": "npm run check:quality && wrangler deploy --dry-run",
    "deploy": "npm run build && wrangler deploy",
    "deploy:ci": "wrangler deploy && npm run smoke:production",
    "deploy:preview": "npm run build && npm run preview:worker",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:worker": "wrangler dev --local --port 8787",
    "smoke:production": "node scripts/check-site.mjs https://arnav-goel.com/"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
